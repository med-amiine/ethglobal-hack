# =============================================================================
# AGENT COURT — Environment Variables
# Copy this file to .env.local and fill in your values.
# Keys marked REQUIRED have no fallback and will break the app if missing.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND — Next.js (client-side, must be prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------------------------

# Ably real-time messaging — publish key for client subscriptions
# Get from: https://ably.com/dashboard → App → API Keys
# REQUIRED — no fallback
NEXT_PUBLIC_ABLY_KEY=

# WalletConnect project ID — used by RainbowKit for wallet modal
# Get from: https://cloud.walletconnect.com
# REQUIRED — current fallback is a shared/insecure demo key
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Backend API base URL
# OPTIONAL — defaults to https://api-service-sand.vercel.app
NEXT_PUBLIC_API_URL=https://api-service-sand.vercel.app

# -----------------------------------------------------------------------------
# BACKEND — Next.js API routes (server-side only, never exposed to client)
# -----------------------------------------------------------------------------

# Pinata IPFS — JWT token for evidence file uploads
# Get from: https://app.pinata.cloud/keys
# REQUIRED — upload route will fail without this
PINATA_JWT=

# Ably server-side API key — for publishing events from API routes
# Get from: https://ably.com/dashboard → App → API Keys (root key with publish rights)
# REQUIRED — realtime webhook handler won't publish without this
ABLY_API_KEY=

# Alchemy API key — for blockchain event listening (Alchemy SDK)
# Get from: https://dashboard.alchemy.com
# REQUIRED — alchemy-listener.ts will fail without this
ALCHEMY_API_KEY=

# -----------------------------------------------------------------------------
# SMART CONTRACTS — Hardhat (used during deployment only)
# -----------------------------------------------------------------------------

# Deployer wallet private key (no 0x prefix)
# REQUIRED for any deployment or contract interaction via scripts
PRIVATE_KEY=

# BaseScan API key — for contract verification on Base networks
# Get from: https://basescan.org/myapikey
# OPTIONAL — only needed for `hardhat verify`
BASESCAN_API_KEY=

# RPC endpoints — all have public fallbacks but rate-limited
# OPTIONAL
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Demo case address for scripts
# OPTIONAL — defaults to 0x483b5cdbf2851E9106eC41A75d92f353aebF0007
CASE_ADDRESS=

# -----------------------------------------------------------------------------
# PYTHON API SERVICE — contracts/api-service/
# -----------------------------------------------------------------------------

# Arbitrum RPC for the FastAPI backend
# OPTIONAL — defaults to https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# API server port
# OPTIONAL — defaults to 8000
PORT=8000
